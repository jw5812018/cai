<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS Web.config - P.O.O. Intranet Configuration
  This file contains sensitive configuration for the admin panel
-->
<configuration>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
    <authentication mode="Forms">
      <forms loginUrl="~/Account/Login" timeout="2880" />
    </authentication>
  </system.web>

  <appSettings>
    <!-- Database Connection -->
    <add key="DbServer" value="10.13.38.12" />
    <add key="DbName" value="poo_public" />
    <add key="DbUser" value="external_user" />

    <!-- Admin Panel Credentials -->
    <add key="AdminUsername" value="Administrator" />
    <add key="AdminPassword" value="EverybodyWantsToWorkAtP.O.O." />

    <!-- Application Settings -->
    <add key="SiteName" value="P.O.O. Intranet Compatibility Portal" />
    <add key="Environment" value="Production" />
  </appSettings>

  <connectionStrings>
    <add name="POO_Connection"
         connectionString="Server=10.13.38.12;Database=poo_public;User Id=external_user;Password=#p00Public3xt3rnalUs3r#;"
         providerName="Npgsql" />
  </connectionStrings>

  <system.webServer>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="web.config" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
